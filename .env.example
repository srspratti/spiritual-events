# Copy this to apps/web/.env for local development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/spiritual_events?schema=public"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000"
ADMIN_TOKEN="change-me-in-production"
CRON_SECRET="change-me-cron-secret"

# Optional integrations. Leave blank until approved/connected.
EVENTBRITE_TOKEN=""
MEETUP_CLIENT_ID=""
MEETUP_CLIENT_SECRET=""
MEETUP_ACCESS_TOKEN=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# Maps/geocoding optional for v1. If blank, app stores textual location only.
GOOGLE_MAPS_API_KEY=""
