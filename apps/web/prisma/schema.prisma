generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  organizer
  admin
}

enum OrganizerTrustLevel {
  pending
  trusted
  blocked
}

enum SourceType {
  manual
  ics
  google_calendar
  meetup
  eventbrite
  facebook
}

enum AuthStatus {
  not_required
  pending
  authorized
  expired
  rejected
}

enum EventStatus {
  pending
  published
  rejected
  cancelled
  duplicate
}

enum ImportStatus {
  success
  partial
  failed
}

model User {
  id          String       @id @default(uuid())
  email       String       @unique
  name        String?
  role        UserRole     @default(user)
  city        String?
  createdAt   DateTime     @default(now()) @map("created_at")
  organizers  Organizer[]
  savedEvents SavedEvent[]

  @@map("users")
}

model Organizer {
  id           String               @id @default(uuid())
  userId       String?              @map("user_id")
  user         User?                @relation(fields: [userId], references: [id])
  name         String
  websiteUrl   String?              @map("website_url")
  contactEmail String?              @map("contact_email")
  trustLevel   OrganizerTrustLevel  @default(pending) @map("trust_level")
  createdAt    DateTime             @default(now()) @map("created_at")
  sources      Source[]
  events       Event[]

  @@map("organizers")
}

model Source {
  id                      String      @id @default(uuid())
  organizerId             String?     @map("organizer_id")
  organizer               Organizer?  @relation(fields: [organizerId], references: [id])
  sourceType              SourceType  @map("source_type")
  sourceName              String?     @map("source_name")
  sourceUrl               String?     @map("source_url")
  externalSourceId        String?     @map("external_source_id")
  authStatus              AuthStatus  @default(not_required) @map("auth_status")
  refreshFrequencyMinutes Int         @default(720) @map("refresh_frequency_minutes")
  lastSyncedAt            DateTime?   @map("last_synced_at")
  isActive                Boolean     @default(true) @map("is_active")
  createdAt               DateTime    @default(now()) @map("created_at")
  events                  Event[]
  importLogs              ImportLog[]

  @@map("sources")
}

model Event {
  id               String       @id @default(uuid())
  sourceId         String?      @map("source_id")
  source           Source?      @relation(fields: [sourceId], references: [id])
  organizerId      String?      @map("organizer_id")
  organizer        Organizer?   @relation(fields: [organizerId], references: [id])
  externalEventId  String?      @map("external_event_id")
  sourceType       SourceType   @map("source_type")
  slug             String       @unique
  title            String
  description      String?
  shortDescription String?      @map("short_description")
  eventUrl         String       @map("event_url")
  imageUrl         String?      @map("image_url")
  startsAt         DateTime     @map("starts_at")
  endsAt           DateTime?    @map("ends_at")
  timezone         String?
  isOnline         Boolean      @default(false) @map("is_online")
  venueName        String?      @map("venue_name")
  address          String?
  city             String?
  region           String?
  country          String?
  lat              Float?
  lng              Float?
  priceMin         Decimal?     @map("price_min")
  priceMax         Decimal?     @map("price_max")
  currency         String?
  status           EventStatus  @default(pending)
  qualityScore     Decimal      @default(0) @map("quality_score")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  topics           EventTopic[]
  savedBy          SavedEvent[]

  @@unique([sourceType, externalEventId])
  @@index([status, startsAt])
  @@index([city])
  @@map("events")
}

model Topic {
  id          String       @id @default(uuid())
  slug        String       @unique
  name        String
  events      EventTopic[]

  @@map("topics")
}

model EventTopic {
  eventId String @map("event_id")
  topicId String @map("topic_id")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([eventId, topicId])
  @@map("event_topics")
}

model SavedEvent {
  userId    String   @map("user_id")
  eventId   String   @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([userId, eventId])
  @@map("saved_events")
}

model ImportLog {
  id           String       @id @default(uuid())
  sourceId     String?      @map("source_id")
  source       Source?      @relation(fields: [sourceId], references: [id])
  status       ImportStatus
  fetchedCount Int          @default(0) @map("fetched_count")
  createdCount Int          @default(0) @map("created_count")
  updatedCount Int          @default(0) @map("updated_count")
  errorMessage String?      @map("error_message")
  createdAt    DateTime     @default(now()) @map("created_at")

  @@map("import_logs")
}
